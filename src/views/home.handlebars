<section>
  <h2>Listado de productos (solo lectura)</h2>
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Imagen</th>
        <th>Título</th>
        <th>Descripción</th>
        <th>Precio</th>
        <th>Stock</th>
        <th>Code</th>
      </tr>
    </thead>
    <tbody>
      {{#if products.length}}
        {{#each products}}
          <tr>
            <td>{{this.id}}</td>
            <td>
              {{#if this.thumbnails.[0]}}
                <img src="{{this.thumbnails.[0]}}" alt="{{this.title}}" class="product-img" />
              {{else}}
                Sin imagen
              {{/if}}
            </td>
            <td>{{this.title}}</td>
            <td>{{this.description}}</td>
            <td>{{this.price}}</td>
            <td>{{this.stock}}</td>
            <td>{{this.code}}</td>
          </tr>
        {{/each}}
      {{else}}
        <tr>
          <td colspan="7">No hay productos cargados.</td>
        </tr>
      {{/if}}
    </tbody>
  </table>
</section>
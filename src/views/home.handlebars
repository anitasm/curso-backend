<section class="page-section">
  <div class="section-heading">
    <h2>Productos destacados</h2>
    <p>Listado general de productos disponibles.</p>
  </div>

  {{#if products.length}}
    <div class="products-grid">
      {{#each products}}
        <article class="product-card">
          {{#if this.thumbnails.[0]}}
            <img src="{{this.thumbnails.[0]}}" alt="{{this.title}}" class="product-image" />
          {{else}}
            <div class="product-image placeholder-image">Sin imagen</div>
          {{/if}}

          <div class="product-content">
            <h3>{{this.title}}</h3>
            <p class="description">{{this.description}}</p>
            <p class="price">${{this.price}}</p>
            <div class="meta-row">
              <span>Stock: {{this.stock}}</span>
              <span>{{this.category}}</span>
            </div>
            <p class="tiny-meta">Code: {{this.code}} · ID: {{this.id}}</p>
          </div>
        </article>
      {{/each}}
    </div>
  {{else}}
    <div class="alert-message">No hay productos cargados.</div>
  {{/if}}
</section>


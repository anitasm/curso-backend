<section>
  <h2>Productos en tiempo real</h2>

  <p id="errorBox" class="error-message"></p>

  <ul id="productsList">
    {{#if products.length}}
      {{#each products}}
        <li>
          <strong>#{{this.id}} - {{this.title}}</strong>
          <span> | {{this.description}} | ${{this.price}} | stock: {{this.stock}} | code: {{this.code}}</span>
          <button type="button" class="delete-btn" data-id="{{this.id}}">Eliminar</button>
        </li>
      {{/each}}
    {{else}}
      <li>No hay productos cargados.</li>
    {{/if}}
  </ul>

  <h3>Agregar producto</h3>
  <form id="addProductForm">
    <input name="title" placeholder="title" required>
    <input name="description" placeholder="description" required>
    <input name="code" placeholder="code" required>
    <input name="price" type="number" step="0.01" placeholder="price" required>
    <select name="status" required>
      <option value="true">true</option>
      <option value="false">false</option>
    </select>
    <input name="stock" type="number" placeholder="stock" required>
    <input name="category" placeholder="category" required>
    <input name="thumbnails" placeholder="thumbnails (img1,img2)">
    <button type="submit">Crear</button>
  </form>
</section>

<script src="/socket.io/socket.io.js"></script>
<script src="/js/realtime.js"></script>
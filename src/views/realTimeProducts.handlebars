<section class="page-section realtime-page">
  <div class="section-heading">
    <h2>Gestión de catálogo</h2>
    <p>Administrá el catálogo de accesorios con altas y bajas en vivo.</p>
  </div>

  <div id="errorBox" class="alert-message hidden" role="alert"></div>

  <div class="realtime-layout">
    <article class="panel-card form-panel">
      <h3>Agregar producto</h3>
      <form id="addProductForm" class="product-form">
        <div class="form-grid">
          <label>
            Título
            <input name="title" placeholder="Ej: Pulsera Aura" required>
          </label>

          <label class="full-width">
            Descripción
            <input name="description" placeholder="Descripción breve del producto" required>
          </label>

          <label>
            Precio
            <input name="price" type="number" step="0.01" min="0" placeholder="0.00" required>
          </label>

          <label>
            Stock
            <input name="stock" type="number" min="0" placeholder="0" required>
          </label>

          <label>
            Categoría
            <input name="category" placeholder="Ej: Pulseras" required>
          </label>

          <label>
            Estado
            <select name="status" required>
              <option value="true">Activo</option>
              <option value="false">Inactivo</option>
            </select>
          </label>

          <label class="full-width">
            Thumbnails (URLs separadas por coma)
            <input name="thumbnails" placeholder="/img/imagen-uno.jpg, /img/imagen-dos.jpg">
          </label>

          <label class="full-width" for="image">
            Cargar imagen del producto
            <input type="file" name="image" id="image" accept="image/png,image/jpeg,image/webp" />
          </label>
        </div>

        <button type="submit" class="primary-btn">Agregar producto</button>
      </form>
    </article>

    <article class="panel-card">
      <h3>Catálogo en vivo</h3>
      <div id="productsList" class="products-grid realtime-grid">
        {{#if products.length}}
          {{#each products}}
            <article class="product-card">
              {{#if this.thumbnails.[0]}}
                <img src="{{this.thumbnails.[0]}}" alt="{{this.title}}" class="product-image" />
              {{else}}
                <div class="product-image placeholder-image">Sin imagen</div>
              {{/if}}
              <div class="product-content">
                <h4>{{this.title}}</h4>
                <p class="description">{{this.description}}</p>
                <p class="price">${{this.price}}</p>
                <div class="meta-row">
                  <span>Stock: {{this.stock}}</span>
                  <span>{{this.category}}</span>
                </div>
                <p class="tiny-meta">Ref. {{this.code}}</p>
                <button type="button" class="delete-btn" data-id="{{this.id}}">Eliminar</button>
              </div>
            </article>
          {{/each}}
        {{else}}
          <div class="alert-message">No hay productos cargados.</div>
        {{/if}}
      </div>
    </article>
  </div>
</section>

<script src="/socket.io/socket.io.js"></script>
<script src="/js/realtime.js"></script>